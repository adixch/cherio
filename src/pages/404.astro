---
import Layout from '@/layouts/Layout.astro';
import Particles from '@/components/Particles.astro';
import Background from '@/components/Background.astro';
import Button from '@/components/Button.astro';
---

<Layout title="404 | Cherio" description="404 | Page not found">
    <Particles />
    <Background />

    <div
        class="section fixed z-30 flex w-full flex-col items-center justify-center gap-8 px-4 text-center"
    >
        <h1 class="gradient-text text-[122px] font-bold">404</h1>
        <h3 class="text-[42px] font-bold md:text-[60px]">
            Oooops... page not found
        </h3>
        <a href="/">
            <Button variant="primary" size="lg" ariaLabel="go to homepage"
                >Go to Homepage</Button
            >
        </a>
    </div>
</Layout>
