---
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "We're not some big fancy company. Just a small group of ambitious people with one goal: Creating the best damn products on earth.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#141418" />
        <meta name="description" content={description} />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>
