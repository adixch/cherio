---
import TextBlock from '@/components/TextBlock.astro';
import Button from '@/components/Button.astro';
import Input from '@/components/Input.astro';
import Footer from '@/components/Footer.astro';

const WEB3FORMS_KEY = import.meta.env.WEB3FORMS_ACCESS_KEY;
---

<section
    id="contact"
    class="section flex w-full flex-col justify-center max-md:gap-40"
>
    <div
        class="flex grow flex-col gap-8 lg:flex-row lg:justify-center lg:gap-16"
    >
        <TextBlock
            label="contact"
            title={'No fear!\nWe are here!'}
            description="If you are looking for an individual solution - we are here to help. Leave your e-mail or write a specific message and we will contact you within 24 hours!"
            showOnMobile={true}
            class="flex basis-full flex-col justify-center gap-4 lg:basis-1/2"
        />

        <div
            class="flex basis-full flex-col justify-center gap-4 lg:max-w-xl lg:basis-1/2"
        >
            <p id="form-status" class="hidden rounded px-4 py-2 font-bold"></p>
            <form
                id="contact-form"
                class="flex w-full flex-col gap-8 md:gap-4"
                action="https://api.web3forms.com/submit"
                method="POST"
            >
                <input
                    type="hidden"
                    name="access_key"
                    value={WEB3FORMS_KEY}
                />
                <input
                    type="checkbox"
                    name="botcheck"
                    class="hidden"
                    tabindex="-1"
                    autocomplete="off"
                />
                <Input
                    element="input"
                    id="name"
                    type="text"
                    name="name"
                    placeholder="Name"
                    required
                />
                <Input
                    element="input"
                    id="email"
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                />
                <Input
                    element="textarea"
                    id="message"
                    name="message"
                    placeholder="Message"
                    required
                />
                <Button
                    variant="secondary"
                    size="md"
                    type="submit"
                    ariaLabel="Contact us"
                    class="mt-4 self-center"
                >
                    contact us
                </Button>
            </form>
        </div>
    </div>
    <Footer />
</section>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const statusEl = document.getElementById('form-status')!;

    function showStatus(message: string, isError: boolean) {
        statusEl.textContent = message;
        statusEl.className = `rounded px-4 py-2 font-bold ${isError ? 'bg-red-600/20 text-red-400' : 'bg-green-600/20 text-green-400'}`;
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusEl.classList.add('hidden');

        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        const submitBtn = form.querySelector(
            'button[type="submit"]'
        ) as HTMLButtonElement;
        submitBtn.disabled = true;

        try {
            const response = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                body: new FormData(form),
            });
            const data = await response.json();

            if (data.success) {
                form.reset();
                showStatus('Message sent successfully! We\'ll be in touch.', false);
            } else {
                throw new Error(data.message);
            }
        } catch (error) {
            showStatus(
                error instanceof Error ? error.message : 'Something went wrong',
                true
            );
        } finally {
            submitBtn.disabled = false;
        }
    });
</script>
