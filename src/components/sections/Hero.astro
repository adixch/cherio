---
import { Image } from 'astro:assets';
import logo from '@/assets/logo.svg';
import Button from '@/components/Button.astro';
---

<section
    id="home"
    class="section flex h-screen w-full flex-col items-center justify-center gap-10"
>
    <Image
        src={logo}
        alt="Cherio logo"
        class="h-12.5 w-full object-contain md:h-15 lg:h-20 2xl:h-25"
        loading="eager"
        fetchpriority="high"
    />
    <Button
        variant="primary"
        size="lg"
        id="hero-cta"
    >
        CONTACT US
    </Button>
</section>

<script>
    document.getElementById('hero-cta')?.addEventListener('click', () => {
        document
            .getElementById('contact')
            ?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
</script>
