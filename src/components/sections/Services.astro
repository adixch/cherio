---
import TextBlock from '@/components/TextBlock.astro';

const services = [
    {
        name: 'quality assurance',
        description:
            "Testers are essential in the software development process, helping to identify bugs, design issues, and usability issues prior to software release. But you don't have to worry about that anymore, because from now on you have us.",
    },
    {
        name: 'ux/ui\ndesign',
        description:
            'Lorem ipsum dolor sit amet consectetur adipiscing elit habitasse, pretium scelerisque felis accumsan dis suspendisse pulvinar, consequat id turpis class nunc mollis etiam.',
    },
    {
        name: 'cms managment',
        description:
            'Viverra convallis lacinia duis litora nascetur metus commodo platea leo posuere, praesent iaculis augue pretium netus odio habitant pellentesque pharetra aliquam tortor, habitasse inceptos curabitur ut ac turpis ornare vivamus sociis.',
    },
    {
        name: 'software development',
        description:
            'Primis ultricies quam convallis et sociosqu facilisi molestie fermentum, dui accumsan taciti placerat diam in hac vulputate, mus risus ad montes erat facilisis natoque.',
    },
];
---

<section
    id="services"
    class="section flex w-full flex-col justify-center gap-8 lg:flex-row lg:gap-16"
>
    <div id="services-text" class="flex flex-col justify-center lg:basis-1/2">
        <div class="services-text-stack grid">
            {
                services.map((item, index) => (
                    <div
                        class:list={[
                            'services-text-item',
                            index === 0 && 'services-text-item--active',
                        ]}
                        aria-hidden={index !== 0 ? 'true' : undefined}
                    >
                        <TextBlock
                            label="our services"
                            title={item.name}
                            description={item.description}
                            showOnMobile={false}
                            headingLevel={index === 0 ? 'h2' : 'div'}
                        />
                    </div>
                ))
            }
        </div>
    </div>

    <div
        id="services-grid"
        class="grid grid-cols-1 content-center gap-8 md:grid-cols-2 md:gap-2 lg:basis-1/2 lg:gap-4"
    >
        {
            services.map((item, index) => (
                <div data-service-index={index}>
                    <div
                        class:list={[
                            'service-item relative h-50 shadow-md transition-all duration-300 max-md:pointer-events-none lg:h-57.5 xl:h-62.5',
                            index === 0 && 'service-item--active',
                        ]}
                    >
                        <div class="service-item__bg h-full rounded-lg overflow-hidden grayscale transition-all duration-500 bg-[url('/img/services.webp')] bg-cover bg-center bg-no-repeat">
                            <span class="service-item__title absolute right-0 bottom-0 w-full uppercase max-md:hidden">
                                {item.name}
                            </span>
                        </div>
                    </div>
                    <div class="mt-5 md:hidden">
                        <h2
                            class="service-mobile__title font-bold uppercase"
                            set:text={item.name}
                        />
                        <p class="service-mobile__desc mt-2.5">
                            {item.description}
                        </p>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<style>
    @media (max-width: 767px) {
        .service-mobile__title {
            font-size: max(2rem, 7vw);
            line-height: 1;
            white-space: pre-wrap;
        }

        .service-mobile__desc {
            font-size: max(0.875rem, 4vw);
        }
    }

    .services-text-item {
        grid-area: 1 / 1;
        visibility: hidden;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .services-text-item--active {
        visibility: visible;
        opacity: 1;
    }

    .service-item::before {
        content: '';
        position: absolute;
        top: -1px;
        left: -1px;
        right: -1px;
        bottom: -1px;
        border-radius: 9px;
        background: linear-gradient(
            to bottom right,
            var(--color-theme-pink),
            var(--color-theme-blue)
        );
        opacity: 0;
        z-index: -1;
        transition: all 0.3s ease;
    }

    .service-item__title {
        transform: scale(1.1);
        transform-origin: bottom right;
        transition: all 0.2s ease 0.1s;
        text-align: right;
        font-weight: 500;
        line-height: 20px;
        padding-right: 3%;
        padding-bottom: 2%;
    }

    .service-item__title::first-line {
        word-spacing: 999px;
    }

    .service-item--active .service-item__bg {
        filter: grayscale(0);
    }

    .service-item--active::before {
        opacity: 1 !important;
    }

    @media (min-width: 768px) {
        .service-item:hover::before {
            opacity: 1;
        }

        .service-item__bg:hover {
            cursor: pointer;
            filter: grayscale(0%);
        }

        .service-item:hover .service-item__title,
        .service-item--active .service-item__title {
            transform: scale(1.2);
        }
    }

    @media (min-width: 1024px) {
        .service-item:hover .service-item__title,
        .service-item--active .service-item__title {
            transform: scale(1.55);
            font-weight: 600;
        }

        .service-item__title {
            padding-right: 4%;
            padding-bottom: 3%;
        }
    }

    @media (min-width: 1280px) {
        .service-item:hover .service-item__title,
        .service-item--active .service-item__title {
            transform: scale(1.8);
        }
    }
</style>

<script>
    const serviceItems = document.querySelectorAll('[data-service-index]');
    const textItems = document.querySelectorAll('.services-text-item');

    serviceItems.forEach((item) => {
        const serviceEl = item.querySelector('.service-item');
        const index = (item as HTMLElement).dataset.serviceIndex;

        serviceEl?.addEventListener('click', () => {
            document
                .querySelectorAll('.service-item')
                .forEach((el) => el.classList.remove('service-item--active'));
            serviceEl.classList.add('service-item--active');

            textItems.forEach((t, i) => {
                const isActive = String(i) === index;
                t.classList.toggle('services-text-item--active', isActive);
                t.setAttribute('aria-hidden', String(!isActive));
            });
        });
    });

    if (window.innerWidth < 768) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    const serviceItem =
                        entry.target.querySelector('.service-item');
                    if (!serviceItem) return;

                    if (entry.isIntersecting) {
                        serviceItem.classList.add('service-item--active');
                    } else {
                        serviceItem.classList.remove('service-item--active');
                    }
                });
            },
            { rootMargin: '-15% 0px -70% 0px' }
        );

        document
            .querySelectorAll('.service-item--active')
            .forEach((el) => el.classList.remove('service-item--active'));

        serviceItems.forEach((item) => observer.observe(item));
    }
</script>
