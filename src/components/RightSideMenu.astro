---
const sectionIds = ['home', 'services', 'about', 'contact'];
---

<div
    id="right-menu"
    class="fixed top-15 right-5 z-40 hidden h-[calc(100vh-60px)] w-17.5 flex-col items-center justify-center gap-8 md:flex"
>
    {
        sectionIds.map((id, index) => (
            <div
                class="gradient-link number-menu-item flex cursor-pointer flex-row items-center justify-center gap-3 font-bold transition-all duration-300 before:h-px before:w-0 before:bg-white before:transition-all before:duration-150 before:ease after:h-px after:w-0 after:bg-white after:transition-all after:duration-150 after:ease"
                data-menu-index={index}
                data-menu-section={id}
            >
                {index + 1}
            </div>
        ))
    }
</div>

<style>
    .number-menu-item--active,
    .number-menu-item:hover {
        color: rgba(255, 255, 255, 0);
        transition: all 0.2s ease;
    }

    .number-menu-item--active::before,
    .number-menu-item--active::after {
        background: linear-gradient(
            to bottom right,
            var(--color-theme-pink) 0%,
            var(--color-theme-blue) 100%
        );
        animation: rainbow 2s ease-in-out infinite;
        background-size: 200% 200%;
    }
</style>

<script>
    const menuItems = document.querySelectorAll('[data-menu-section]');
    const container = document.getElementById('container')!;
    const sections = document.querySelectorAll('.section');

    menuItems.forEach((item) => {
        item.addEventListener('click', () => {
            const sectionId = (item as HTMLElement).dataset.menuSection!;
            const target = document.getElementById(sectionId);
            target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });

    function updateActiveNumber() {
        const sectionElements = Array.from(sections);
        let activeIndex = 0;

        for (let i = sectionElements.length - 1; i >= 0; i--) {
            const rect = sectionElements[i].getBoundingClientRect();
            if (rect.top <= 150) {
                activeIndex = i;
                break;
            }
        }

        menuItems.forEach((item, index) => {
            if (index === activeIndex) {
                item.classList.add(
                    'number-menu-item--active',
                    'before:!w-4',
                    'after:!w-4'
                );
            } else {
                item.classList.remove(
                    'number-menu-item--active',
                    'before:!w-4',
                    'after:!w-4'
                );
            }
        });
    }

    const scrollTarget = container.scrollHeight > container.clientHeight ? container : window;
    scrollTarget.addEventListener('scroll', updateActiveNumber);
    updateActiveNumber();
</script>
